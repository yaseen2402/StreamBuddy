# Google API Key for Gemini
GOOGLE_API_KEY=your_api_key_here

# Audio Mode Configuration
# Set to "true" for remote deployment (audio via WebSocket)
# Set to "false" for local development (audio via system devices)
REMOTE_AUDIO_MODE=true

# Proactive Audio Mode
# Set to "true" for streaming mode (AI decides when to speak, adds 5-10s delay)
# Set to "false" for conversational mode (AI responds immediately, lower latency)
# Recommended: false for direct conversation, true for passive stream watching
PROACTIVE_AUDIO_MODE=false

# YouTube OAuth Configuration (optional, for YouTube mode)
YOUTUBE_OAUTH_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/youtube/callback
